# ==== E-POIN: Pretty URL (hapus .php) + Security baseline ====
ServerSignature Off

<IfModule mod_headers.c>
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set X-XSS-Protection "1; mode=block"
  # Aktifkan setelah situs sudah HTTPS semua:
  # Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
</IfModule>

Options -Indexes -MultiViews
RewriteEngine On

# (Opsional) paksa HTTPS setelah SSL siap:
# RewriteCond %{HTTPS} !=on
# RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

# 1) Kalau ada file/folder beneran, langsung layani (CSS/JS/IMG aman)
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# 2) Pretty URL: /epoin/admin/mapel  ->  /epoin/admin/mapel.php  (internal; user gak lihat .php)
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.+?)/?$ $1.php [L]

# 3) Canonical: GET/HEAD ke .php dialihkan ke versi tanpa .php (POST tidak di-redirect)
RewriteCond %{THE_REQUEST} \s/+(.+?)\.php(\s|\?)
RewriteCond %{REQUEST_METHOD} !POST
RewriteRule ^ %1 [R=301,L]

# 4) Proteksi file sensitif
<FilesMatch "^(koneksi|config|composer|package|readme|README)\.(php|json|lock|md)$">
  Require all denied
</FilesMatch>
<FilesMatch "\.(env|ini|log|bak|sql|sh|tpl|inc)$">
  Require all denied
</FilesMatch>

# 5) Blok akses langsung ke folder berbahaya jika kebawa ke webroot
RewriteRule ^(?:vendor|tests|backup|backups|\.git)/ - [R=404,L]
