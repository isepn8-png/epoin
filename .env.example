# Copy to .env and adjust per environment (never commit .env).
APP_ENV=local

DB_HOST=127.0.0.1
DB_PORT=3308
DB_DATABASE=epoin_local
DB_USERNAME=root
DB_PASSWORD=

# Production example (set APP_ENV=production on VPS/shared hosting):
# APP_ENV=production
# DB_HOST=localhost
# DB_PORT=3306
# DB_DATABASE=your_db_name
# DB_USERNAME=your_db_user
# DB_PASSWORD=your_db_password

# --- Secrets keamanan (WAJIB diganti di production; jangan pakai default) ---
# Webhook auto-deploy GitHub (HMAC-SHA256)
# DEPLOY_WEBHOOK_SECRET=ganti_dengan_random_panjang
# PIN faktor-kedua untuk reset usage di admin/HOSTING.php (default lama: 123456)
# HOSTING_RESET_PIN=
# PIN faktor-kedua untuk generator kode lisensi admin/KODE.php (default lama: 789789)
# KODE_PIN=
